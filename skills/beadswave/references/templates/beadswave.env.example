# .beadswave.env — per-repo override for bd-ship gate commands.
#
# Copy this file to your repo root as `.beadswave.env` and edit.
# bd-ship sources this file before running the lint / typecheck / tests
# gates. Anything you set here overrides the skill's stack auto-detection.
#
# Precedence (high wins):
#   1. Env var at invocation      (e.g.  LINT_CMD="..." bd-ship ...)
#   2. .beadswave.env in repo root (this file)
#   3. Stack auto-detection from lockfile (bun.lock, pnpm-lock.yaml, etc.)
#
# Set a command to "" (empty string) to disable that gate repo-wide.
# Set a command to a specific filter to scope the gate (e.g. backend only).

# LINT_CMD="bun run lint"
# TYPECHECK_CMD="bun run typecheck"
# TEST_CMD="bun run test --run"
# Choose the GitHub auto-merge strategy used by bd-ship fallback:
# BEADSWAVE_GH_PR_MERGE_METHOD="squash"
# Tune queue hygiene during scripts/mass-ship.sh streams:
# BEADSWAVE_MASS_SHIP_QUEUE_HYGIENE=1
# BEADSWAVE_MASS_SHIP_PRUNE_MAX=25
# BEADSWAVE_MASS_SHIP_MONITOR_STUCK_MINUTES=30
# bd-ship defaults PRESHIP_ISOLATE=1. Leave it unset for the safe default.
# Set to 0 only if you intentionally want legacy non-isolated behaviour.
# PRESHIP_ISOLATE=0

# Examples:
#   # Run lint + typecheck only on the backend package:
#   LINT_CMD="bun run --filter backend lint"
#   TYPECHECK_CMD="bun run --filter backend typecheck"
#
#   # Disable a gate for repos that don't have it (e.g. Python repo with no mypy):
#   TYPECHECK_CMD=""
#
#   # Use a custom smoke test:
#   TEST_CMD="bun run test:smoke"
#
#   # Opt out of bd-ship's default isolation check (not recommended):
#   PRESHIP_ISOLATE=0
