{
  "name": "spec-generator",
  "version": "1.0.0",
  "description": "Generate documentation and types from SSOT YAML specifications",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "generate": "node dist/index.js",
    "generate:docs": "node dist/index.js --docs",
    "generate:ts": "node dist/index.js --typescript",
    "validate": "node dist/index.js --validate",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^10.3.10",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
